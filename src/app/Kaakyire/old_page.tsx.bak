"use client";

import { useState, useEffect } from "react";
import { 
  BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer,
  LineChart, Line, PieChart, Pie, Cell
} from 'recharts';
import { 
  Square3Stack3DIcon, 
  ShoppingBagIcon, 
  ChartBarIcon, 
  ArrowLeftOnRectangleIcon,
  PlusIcon,
  TrashIcon,
  EyeIcon,
  EyeSlashIcon
} from "@heroicons/react/24/outline";

type Product = { id: string; name: string; description: string; price: number; imageUrl: string | null; category: string; isAvailable: boolean; };
type Order = { id: string; customerName: string; customerPhone: string; location: string; items: any; totalAmount: number; status: string; createdAt: string; };

export default function AdminDashboard() {
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [password, setPassword] = useState("");
  const [activeTab, setActiveTab] = useState("overview");
  
  const [products, setProducts] = useState<Product[]>([]);
  const [orders, setOrders] = useState<Order[]>([]);
  const [loading, setLoading] = useState(false);
  
  // New product form
  const [newProduct, setNewProduct] = useState({ name: "", description: "", price: "", imageUrl: "", category: "General" });

  const handleLogin = async (e: React.FormEvent) => {
    e.preventDefault();
    const res = await fetch('/api/admin/login', { method: 'POST', body: JSON.stringify({ password }) });
    if (res.ok) { 
      setIsAuthenticated(true); 
      fetchDashboardData(); 
    } else {
      alert("Invalid credentials");
    }
  };

  const fetchDashboardData = async () => {
    setLoading(true);
    try {
      const pRes = await fetch('/api/products');
      const pData = pRes.ok ? await pRes.json() : [];
      setProducts(Array.isArray(pData) ? pData : []);

      const oRes = await fetch('/api/orders');
      const oData = oRes.ok ? await oRes.json() : [];
      setOrders(Array.isArray(oData) ? oData : []);
    } catch (error) {
      console.error("Failed to fetch dashboard data", error);
      setProducts([]);
      setOrders([]);
    }
    setLoading(false);
  };

  const handleAddProduct = async (e: React.FormEvent) => {
    e.preventDefault();
    await fetch('/api/products', { method: 'POST', body: JSON.stringify(newProduct) });
    setNewProduct({ name: "", description: "", price: "", imageUrl: "", category: "General" });
    fetchDashboardData();
  };

  const toggleProductStatus = async (id: string, currentStatus: boolean) => {
    await fetch(`/api/products/${id}`, { method: 'PUT', body: JSON.stringify({ isAvailable: !currentStatus }) });
    fetchDashboardData();
  };

  const deleteProduct = async (id: string) => {
    if(confirm('Are you sure you want to delete this product?')) {
      await fetch(`/api/products/${id}`, { method: 'DELETE' });
      fetchDashboardData();
    }
  };

  // Stats for Charts
  const chartData = [
    { name: 'Products', count: products.length, color: '#4a0336' },
    { name: 'Orders', count: orders.length, color: '#b76e79' },
  ];

  // Sales trend (mock logic based on existing orders)
  const salesData = orders.slice(-7).map((o, i) => ({
    name: new Date(o.createdAt).toLocaleDateString(undefined, { weekday: 'short' }),
    total: o.totalAmount
  }));

  if (!isAuthenticated) {
    return (
      <div className="min-h-[80vh] flex items-center justify-center bg-gray-50 dark:bg-transparent px-4">
        <div className="bg-white dark:bg-[#1E1E1E] p-8 rounded-2xl shadow-xl w-full max-w-md border border-gray-100 dark:border-gray-800 text-center">
          <div className="w-16 h-16 bg-brand-plum/10 dark:bg-brand-rosegold/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <ShoppingBagIcon className="w-8 h-8 text-brand-plum dark:text-brand-rosegold" />
          </div>
          <h2 className="text-3xl font-serif mb-2 text-brand-plum dark:text-brand-rosegold">Admin Access</h2>
          <p className="text-gray-500 mb-8">Secure management for Glow By Connie</p>
          <form onSubmit={handleLogin} className="space-y-4">
            <input 
              type="password" 
              value={password} 
              onChange={e => setPassword(e.target.value)} 
              placeholder="Enter admin password" 
              required 
              className="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 focus:ring-2 focus:ring-brand-plum dark:focus:ring-brand-rosegold outline-none transition"
            />
            <button type="submit" className="w-full bg-brand-plum hover:bg-brand-plum/90 dark:bg-brand-rosegold dark:hover:bg-brand-rosegold/90 text-white dark:text-black font-bold py-3 rounded-lg transition-transform active:scale-95 shadow-lg">
              Unlock Dashboard
            </button>
          </form>
        </div>
      </div>
    );
  }

  return (
    <div className="flex flex-col md:flex-row min-h-screen bg-gray-50 dark:bg-transparent gap-6">
      {/* Sidebar */}
      <div className="w-full md:w-64 bg-white dark:bg-[#1E1E1E] rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-6 self-start md:sticky md:top-24">
        <h3 className="text-xs font-bold uppercase tracking-widest text-gray-400 mb-6 px-3">Main Menu</h3>
        <nav className="space-y-2">
          <button 
            onClick={() => setActiveTab('overview')}
            className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${activeTab === 'overview' ? 'bg-brand-plum text-white shadow-md' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800'}`}
          >
            <ChartBarIcon className="w-5 h-5" />
            <span className="font-medium">Overview</span>
          </button>
          <button 
            onClick={() => setActiveTab('products')}
            className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${activeTab === 'products' ? 'bg-brand-plum text-white shadow-md' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800'}`}
          >
            <Square3Stack3DIcon className="w-5 h-5" />
            <span className="font-medium">Inventory</span>
          </button>
          <button 
            onClick={() => setActiveTab('orders')}
            className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${activeTab === 'orders' ? 'bg-brand-plum text-white shadow-md' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800'}`}
          >
            <ShoppingBagIcon className="w-5 h-5" />
            <span className="font-medium">Orders</span>
          </button>
          
          <div className="pt-8 mt-8 border-t border-gray-100 dark:border-gray-800">
            <button 
              onClick={() => setIsAuthenticated(false)}
              className="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 transition-all"
            >
              <ArrowLeftOnRectangleIcon className="w-5 h-5" />
              <span className="font-medium">Logout</span>
            </button>
          </div>
        </nav>
      </div>
      
      {/* Content Area */}
      <div className="flex-1">
        {loading ? (
          <div className="flex flex-col items-center justify-center p-12 space-y-4 animate-pulse">
            <div className="w-12 h-12 border-4 border-brand-plum border-t-transparent rounded-full animate-spin"></div>
            <p className="text-gray-500 font-medium">Synchronizing data...</p>
          </div>
        ) : (
          <div className="space-y-6">
            
            {activeTab === 'overview' && (
              <div className="animate-in fade-in slide-in-from-bottom-4 duration-500">
                <h2 className="text-3xl font-serif text-brand-plum dark:text-brand-rosegold mb-6">Business Insights</h2>
                
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                  <div className="bg-white dark:bg-[#1E1E1E] p-6 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm">
                    <p className="text-gray-500 text-sm mb-1 uppercase tracking-wider">Total Sales</p>
                    <h3 className="text-3xl font-bold text-green-600 dark:text-green-400">GHC {orders.reduce((s,o) => s + o.totalAmount, 0).toLocaleString()}</h3>
                  </div>
                  <div className="bg-white dark:bg-[#1E1E1E] p-6 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm">
                    <p className="text-gray-500 text-sm mb-1 uppercase tracking-wider">Active Products</p>
                    <h3 className="text-3xl font-bold text-brand-plum dark:text-brand-rosegold">{products.filter(p => p.isAvailable).length}</h3>
                  </div>
                  <div className="bg-white dark:bg-[#1E1E1E] p-6 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm">
                    <p className="text-gray-500 text-sm mb-1 uppercase tracking-wider">Total Orders</p>
                    <h3 className="text-3xl font-bold text-blue-600 dark:text-blue-400">{orders.length}</h3>
                  </div>
                </div>

                <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                  <div className="bg-white dark:bg-[#1E1E1E] p-6 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-xl min-h-[400px]">
                    <h4 className="text-lg font-bold mb-6">Recent Sales Trend</h4>
                    <ResponsiveContainer width="100%" height={300}>
                      <LineChart data={salesData}>
                        <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#eee" />
                        <XAxis dataKey="name" axisLine={false} tickLine={false} dy={10} />
                        <YAxis axisLine={false} tickLine={false} />
                        <Tooltip contentStyle={{ borderRadius: '12px', border: 'none', boxShadow: '0 10px 15px -3px rgba(0,0,0,0.1)' }} />
                        <Line type="monotone" dataKey="total" stroke="#b76e79" strokeWidth={4} dot={{ r: 6, fill: '#b76e79' }} activeDot={{ r: 8 }} />
                      </LineChart>
                    </ResponsiveContainer>
                  </div>

                  <div className="bg-white dark:bg-[#1E1E1E] p-6 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-xl min-h-[400px]">
                    <h4 className="text-lg font-bold mb-6">Catalog Composition</h4>
                    <ResponsiveContainer width="100%" height={300}>
                      <BarChart data={chartData}>
                        <CartesianGrid strokeDasharray="3 3" vertical={false} />
                        <XAxis dataKey="name" />
                        <YAxis />
                        <Tooltip cursor={{fill: 'transparent'}} />
                        <Bar dataKey="count" radius={[10, 10, 0, 0]}>
                          {chartData.map((entry, index) => (
                            <Cell key={`cell-${index}`} fill={entry.color} />
                          ))}
                        </Bar>
                      </BarChart>
                    </ResponsiveContainer>
                  </div>
                </div>
              </div>
            )}
            
            {activeTab === 'products' && (
              <div className="animate-in fade-in slide-in-from-bottom-4 duration-500">
                <div className="flex justify-between items-center mb-6">
                  <h2 className="text-3xl font-serif text-brand-plum dark:text-brand-rosegold">Inventory</h2>
                </div>
                
                {/* Add Product Section */}
                <div className="bg-brand-plum/5 dark:bg-brand-rosegold/5 p-8 rounded-2xl border border-dashed border-brand-plum/20 dark:border-brand-rosegold/20 mb-8">
                  <div className="flex items-center gap-2 mb-6">
                    <PlusIcon className="w-6 h-6 text-brand-plum dark:text-brand-rosegold" />
                    <h3 className="text-xl font-bold">Launch New Product</h3>
                  </div>
                  <form onSubmit={handleAddProduct} className="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div className="md:col-span-2">
                       <label className="text-xs font-bold uppercase text-gray-500 mb-1 block">Product Name</label>
                       <input required className="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800" placeholder="e.g. Lavender Night Cream" value={newProduct.name} onChange={e => setNewProduct({...newProduct, name: e.target.value})} />
                    </div>
                    <div>
                      <label className="text-xs font-bold uppercase text-gray-500 mb-1 block">Price (GHC)</label>
                      <input required type="number" className="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800" placeholder="0.00" value={newProduct.price} onChange={e => setNewProduct({...newProduct, price: e.target.value})} />
                    </div>
                    <div>
                      <label className="text-xs font-bold uppercase text-gray-500 mb-1 block">Category</label>
                      <input className="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800" placeholder="Skincare" value={newProduct.category} onChange={e => setNewProduct({...newProduct, category: e.target.value})} />
                    </div>
                    <div className="md:col-span-2">
                      <label className="text-xs font-bold uppercase text-gray-500 mb-1 block">Description</label>
                      <input required className="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800" placeholder="Product details..." value={newProduct.description} onChange={e => setNewProduct({...newProduct, description: e.target.value})} />
                    </div>
                    <div className="md:col-span-2">
                      <label className="text-xs font-bold uppercase text-gray-500 mb-1 block">Image Link</label>
                      <input className="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800" placeholder="https://..." value={newProduct.imageUrl} onChange={e => setNewProduct({...newProduct, imageUrl: e.target.value})} />
                    </div>
                    <div className="flex items-end">
                      <button type="submit" className="w-full bg-brand-plum dark:bg-brand-rosegold text-white dark:text-black font-bold py-2 rounded-lg shadow-md hover:shadow-lg transition">
                        Save to Catalog
                      </button>
                    </div>
                  </form>
                </div>

                <div className="bg-white dark:bg-[#1E1E1E] rounded-2xl shadow-xl overflow-hidden border border-gray-100 dark:border-gray-800">
                  <table className="w-full text-left border-collapse">
                    <thead>
                      <tr className="bg-gray-50 dark:bg-gray-800/50 text-gray-500 text-xs font-bold uppercase tracking-wider">
                        <th className="px-6 py-4">Item Details</th>
                        <th className="px-6 py-4">Price</th>
                        <th className="px-6 py-4">Status</th>
                        <th className="px-6 py-4 text-right">Settings</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-gray-100 dark:divide-gray-800">
                      {Array.isArray(products) && products.map(p => (
                        <tr key={p.id} className="hover:bg-gray-50 dark:hover:bg-gray-800/20 transition-colors">
                          <td className="px-6 py-4">
                            <div className="font-bold text-gray-900 dark:text-white">{p.name}</div>
                            <div className="text-xs text-gray-500">{p.category}</div>
                          </td>
                          <td className="px-6 py-4 font-medium text-brand-plum dark:text-brand-rosegold">GHC {p.price}</td>
                          <td className="px-6 py-4">
                            <span className={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide ${p.isAvailable ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300' : 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300'}`}>
                              {p.isAvailable ? 'Live' : 'Hidden'}
                            </span>
                          </td>
                          <td className="px-6 py-4 text-right flex justify-end gap-2">
                            <button 
                              onClick={() => toggleProductStatus(p.id, p.isAvailable)} 
                              className="p-2 text-gray-400 hover:text-brand-plum dark:hover:text-brand-rosegold transition-colors"
                              title={p.isAvailable ? 'Hide from Store' : 'Show in Store'}
                            >
                              {p.isAvailable ? <EyeSlashIcon className="w-5 h-5" /> : <EyeIcon className="w-5 h-5" />}
                            </button>
                            <button 
                              onClick={() => deleteProduct(p.id)} 
                              className="p-2 text-gray-400 hover:text-red-600 transition-colors"
                              title="Permenant Delete"
                            >
                              <TrashIcon className="w-5 h-5" />
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                  {products.length === 0 && <div className="p-12 text-center text-gray-400 italic">No products launched yet.</div>}
                </div>
              </div>
            )}

            {activeTab === 'orders' && (
              <div className="animate-in fade-in slide-in-from-bottom-4 duration-500">
                <h2 className="text-3xl font-serif text-brand-plum dark:text-brand-rosegold mb-6">Recent Orders</h2>
                {orders.length === 0 ? (
                  <div className="bg-white dark:bg-[#1E1E1E] p-12 rounded-2xl text-center border border-gray-100 dark:border-gray-800 shadow-sm">
                    <ShoppingBagIcon className="w-12 h-12 mx-auto text-gray-200 mb-4" />
                    <p className="text-gray-500">No customers have placed orders yet.</p>
                  </div>
                ) : (
                  <div className="grid grid-cols-1 xl:grid-cols-2 gap-6">
                    {orders.map(order => (
                      <div key={order.id} className="bg-white dark:bg-[#1E1E1E] rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-xl transition-all p-6 group">
                        <div className="flex justify-between items-start mb-6 border-b border-gray-50 dark:border-gray-800 pb-4">
                          <div>
                            <h3 className="text-xl font-bold text-gray-900 dark:text-white group-hover:text-brand-plum dark:group-hover:text-brand-rosegold transition-colors">{order.customerName}</h3>
                            <div className="text-xs text-gray-400 mt-1 uppercase tracking-tighter">{new Date(order.createdAt).toLocaleString()}</div>
                          </div>
                          <div className="text-right">
                             <div className="text-2xl font-black text-brand-plum dark:text-brand-rosegold">GHC {order.totalAmount}</div>
                          </div>
                        </div>
                        
                        <div className="space-y-3 mb-6">
                           <div className="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                              <span className="w-6 text-center text-lg">📞</span>
                              <span>{order.customerPhone}</span>
                           </div>
                           <div className="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                              <span className="w-6 text-center text-lg">📍</span>
                              <span className="line-clamp-1">{order.location}</span>
                           </div>
                        </div>
                        
                        <div className="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-xl space-y-2">
                          <p className="text-[10px] font-bold uppercase text-gray-400 mb-1">Items Summary</p>
                          {(order.items as any[]).map((item, idx) => (
                            <div key={idx} className="flex justify-between text-sm">
                              <span className="text-gray-700 dark:text-gray-300"><span className="font-bold text-brand-plum dark:text-brand-rosegold mr-2">{item.quantity}x</span> {item.name}</span>
                              <span className="text-gray-400 italic text-xs">GHC {item.price * item.quantity}</span>
                            </div>
                          ))}
                        </div>
                        
                        <div className="mt-6 flex justify-end">
                          <button className="text-xs font-bold uppercase tracking-widest text-[#25D366] hover:underline flex items-center gap-1" onClick={() => window.open(`https://wa.me/${order.customerPhone.replace(/[^0-9]/g, '')}`, '_blank')}>
                            Contact via WhatsApp
                          </button>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
